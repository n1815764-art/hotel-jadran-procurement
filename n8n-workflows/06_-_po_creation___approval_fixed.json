    {
      "parameters": {
        "jsCode": "// Parse AI email draft and generate professional HTML PO document\nconst response = $input.first().json;\nconst content = response.choices[0].message.content;\nconst parsed = JSON.parse(content.replace(/```json|```/g, '').trim());\nconst poData = $('Code - Extract PO Data').first().json;\n\n// Parse line items\nlet lineItems = [];\ntry {\n  lineItems = JSON.parse(poData.items_json || '[]');\n} catch(e) {\n  lineItems = [{ item_name: 'Items as specified', quantity: 1, unit: 'lot', unit_price: poData.total_amount }];\n}\n\n// Build line items HTML rows\nconst lineItemsHtml = lineItems.map((item, i) => {\n  const subtotal = (item.quantity * item.unit_price).toFixed(2);\n  return '<tr>' +\n    '<td style=\"padding:8px 12px;border-bottom:1px solid #e5e7eb;\">' + (i+1) + '</td>' +\n    '<td style=\"padding:8px 12px;border-bottom:1px solid #e5e7eb;\">' + item.item_name + '</td>' +\n    '<td style=\"padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:center;\">' + item.quantity + '</td>' +\n    '<td style=\"padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:center;\">' + (item.unit || 'each') + '</td>' +\n    '<td style=\"padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:right;\">€' + Number(item.unit_price).toFixed(2) + '</td>' +\n    '<td style=\"padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:right;\">€' + subtotal + '</td>' +\n    '</tr>';\n}).join('');\n\nconst today = new Date().toISOString().split('T')[0];\n\nconst htmlDocument = '<!DOCTYPE html>' +\n'<html><head><meta charset=\"utf-8\"></head><body style=\"font-family:Arial,Helvetica,sans-serif;color:#1a1a1a;margin:0;padding:0;\">' +\n\n// Header bar\n'<div style=\"background:#1e3a5f;padding:24px 40px;color:white;\">' +\n  '<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>' +\n    '<td>' +\n      '<h1 style=\"margin:0;font-size:28px;font-weight:700;letter-spacing:1px;\">HOTEL JADRAN</h1>' +\n      '<p style=\"margin:4px 0 0;font-size:13px;color:#a0c4e8;\">Obala bb, Budva, Montenegro</p>' +\n      '<p style=\"margin:2px 0 0;font-size:13px;color:#a0c4e8;\">procurement@hoteljadran.me | +382 33 123 456</p>' +\n    '</td>' +\n    '<td style=\"text-align:right;\">' +\n      '<p style=\"margin:0;font-size:36px;font-weight:700;color:white;letter-spacing:2px;\">PURCHASE ORDER</p>' +\n    '</td>' +\n  '</tr></table>' +\n'</div>' +\n\n// PO Info + Vendor Info\n'<div style=\"padding:24px 40px;\">' +\n  '<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>' +\n    '<td style=\"vertical-align:top;width:50%;\">' +\n      '<div style=\"background:#f0f4f8;border-radius:6px;padding:16px;margin-right:12px;\">' +\n        '<p style=\"margin:0 0 8px;font-size:11px;text-transform:uppercase;color:#6b7280;font-weight:600;\">Purchase Order Details</p>' +\n        '<table cellpadding=\"2\" cellspacing=\"0\" style=\"font-size:14px;\">' +\n          '<tr><td style=\"color:#6b7280;padding-right:12px;\">PO Number:</td><td style=\"font-weight:600;\">' + poData.po_number + '</td></tr>' +\n          '<tr><td style=\"color:#6b7280;padding-right:12px;\">Date:</td><td>' + today + '</td></tr>' +\n          '<tr><td style=\"color:#6b7280;padding-right:12px;\">Department:</td><td>' + (poData.department || 'General') + '</td></tr>' +\n          '<tr><td style=\"color:#6b7280;padding-right:12px;\">GL Account:</td><td>' + (poData.gl_account || 'N/A') + '</td></tr>' +\n          '<tr><td style=\"color:#6b7280;padding-right:12px;\">Requested by:</td><td>' + (poData.requester || 'System') + '</td></tr>' +\n        '</table>' +\n      '</div>' +\n    '</td>' +\n    '<td style=\"vertical-align:top;width:50%;\">' +\n      '<div style=\"background:#f0f4f8;border-radius:6px;padding:16px;margin-left:12px;\">' +\n        '<p style=\"margin:0 0 8px;font-size:11px;text-transform:uppercase;color:#6b7280;font-weight:600;\">Vendor</p>' +\n        '<p style=\"margin:0;font-size:16px;font-weight:600;\">' + poData.vendor_name + '</p>' +\n        '<p style=\"margin:4px 0 0;font-size:14px;color:#4b5563;\">' + (poData.vendor_email || '') + '</p>' +\n      '</div>' +\n    '</td>' +\n  '</tr></table>' +\n'</div>' +\n\n// Line Items Table\n'<div style=\"padding:0 40px 24px;\">' +\n  '<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e5e7eb;border-radius:6px;overflow:hidden;font-size:14px;\">' +\n    '<thead>' +\n      '<tr style=\"background:#1e3a5f;color:white;\">' +\n        '<th style=\"padding:10px 12px;text-align:left;font-weight:600;\">#</th>' +\n        '<th style=\"padding:10px 12px;text-align:left;font-weight:600;\">Item Description</th>' +\n        '<th style=\"padding:10px 12px;text-align:center;font-weight:600;\">Qty</th>' +\n        '<th style=\"padding:10px 12px;text-align:center;font-weight:600;\">Unit</th>' +\n        '<th style=\"padding:10px 12px;text-align:right;font-weight:600;\">Unit Price</th>' +\n        '<th style=\"padding:10px 12px;text-align:right;font-weight:600;\">Subtotal</th>' +\n      '</tr>' +\n    '</thead>' +\n    '<tbody>' + lineItemsHtml + '</tbody>' +\n    '<tfoot>' +\n      '<tr style=\"background:#f9fafb;\">' +\n        '<td colspan=\"5\" style=\"padding:12px;text-align:right;font-weight:700;font-size:16px;\">TOTAL:</td>' +\n        '<td style=\"padding:12px;text-align:right;font-weight:700;font-size:16px;color:#1e3a5f;\">€' + Number(poData.total_amount).toFixed(2) + '</td>' +\n      '</tr>' +\n    '</tfoot>' +\n  '</table>' +\n'</div>' +\n\n// Terms & Signature\n'<div style=\"padding:0 40px 24px;\">' +\n  '<div style=\"border-top:2px solid #e5e7eb;padding-top:16px;\">' +\n    '<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>' +\n      '<td style=\"vertical-align:top;width:50%;padding-right:20px;\">' +\n        '<p style=\"margin:0 0 6px;font-size:11px;text-transform:uppercase;color:#6b7280;font-weight:600;\">Terms & Conditions</p>' +\n        '<p style=\"margin:0;font-size:13px;color:#4b5563;line-height:1.5;\">' +\n          '1. Payment terms: Net 30 from delivery date.<br>' +\n          '2. Delivery to: Hotel Jadran, Obala bb, Budva.<br>' +\n          '3. Invoice must reference this PO number.<br>' +\n          '4. Prices are in EUR and include all applicable charges.' +\n        '</p>' +\n      '</td>' +\n      '<td style=\"vertical-align:top;width:50%;text-align:right;\">' +\n        '<p style=\"margin:0 0 6px;font-size:11px;text-transform:uppercase;color:#6b7280;font-weight:600;\">Authorized by</p>' +\n        '<div style=\"border-bottom:1px solid #1a1a1a;width:200px;display:inline-block;margin-bottom:6px;\">&nbsp;</div>' +\n        '<p style=\"margin:0;font-size:13px;color:#4b5563;\">Procurement Department<br>Hotel Jadran</p>' +\n        '<p style=\"margin:8px 0 0;font-size:12px;color:#9ca3af;\">Date: ' + today + '</p>' +\n      '</td>' +\n    '</tr></table>' +\n  '</div>' +\n'</div>' +\n\n// Footer\n'<div style=\"background:#f0f4f8;padding:12px 40px;text-align:center;font-size:11px;color:#9ca3af;\">' +\n  'This is an automatically generated purchase order from Hotel Jadran Procurement System. ' +\n  'For questions, contact procurement@hoteljadran.me' +\n'</div>' +\n\n'</body></html>';\n\nreturn [{ json: {\n  ...poData,\n  email_subject: 'Purchase Order ' + poData.po_number + ' — Hotel Jadran',\n  email_body: htmlDocument\n} }];"
      },
