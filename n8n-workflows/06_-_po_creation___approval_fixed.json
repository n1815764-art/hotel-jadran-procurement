      "parameters": {
        "jsCode": "// Generate PO record and prepare Airtable payload\nconst data = $input.first().json.body || $input.first().json;\n\nconst poNum = 'PO-' + new Date().getFullYear() + '-' + String(Date.now()).slice(-4);\nconst totalAmount = data.total_amount || (data.quantity_requested * (data.unit_cost || 0));\n\nconst poRecord = {\n  po_number: poNum,\n  vendor_name: data.vendor_name || 'TBD',\n  vendor_email: data.vendor_email || '',\n  department: data.department || '',\n  total_amount: totalAmount,\n  items_json: data.items_json || JSON.stringify([{ item_name: data.item_name, quantity: data.quantity_requested || data.approved_quantity, unit: data.unit || 'each', unit_price: data.unit_cost || 0 }]),\n  gl_account: data.gl_code || data.gl_account || '',\n  source: data.source || 'Manual',\n  requester: data.requester || 'System',\n  status: 'Pending Approval'\n};\n\nconst createBody = JSON.stringify({ records: [{ fields: poRecord }] });\n\nreturn [{ json: { ...poRecord, total_amount: totalAmount, create_body: createBody } }];"
      },
