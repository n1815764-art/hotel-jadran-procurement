{
  "name": "04 - AI Validation",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ai-validate",
        "responseMode": "responseNode"
      },
      "id": "p1q2r3s4-t5u6-7890-vwxy-z12345678901",
      "name": "Webhook - Validate",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "ai-validate"
    },
    {
      "parameters": {
        "operation": "select",
        "schema": "public",
        "table": "requisitions",
        "where": {
          "conditions": [
            {
              "column": "requisition_id",
              "value": "={{ $json.body.requisitionId || $json.requisitionId }}",
              "condition": "equal"
            }
          ]
        }
      },
      "id": "q2r3s4t5-u6v7-8901-wxyz-a23456789012",
      "name": "Get Requisition",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [450, 300],
      "credentials": {
        "postgres": {
          "id": "postgres-local",
          "name": "Local Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "select",
        "schema": "public",
        "table": "inventory",
        "where": {
          "conditions": [
            {
              "column": "item_name",
              "value": "={{ $json.item_name }}",
              "condition": "equal"
            }
          ]
        }
      },
      "id": "r3s4t5u6-v7w8-9012-xyza-b34567890123",
      "name": "Get Inventory Data",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [650, 300],
      "credentials": {
        "postgres": {
          "id": "postgres-local",
          "name": "Local Postgres"
        }
      }
    },
    {
      "parameters": {
        "model": "claude-3-5-sonnet-20241022",
        "messages": {
          "message": [
            {
              "role": "system",
              "content": "={{ $readFile('/Users/agent0/Documents/Replacement/claude-prompts/requisition-validator.md') }}"
            },
            {
              "role": "user",
              "content": "={{ JSON.stringify({\n  requisition: {\n    id: $json.requisition_id,\n    department: $json.department,\n    item_name: $json.item_name,\n    sku: $json.sku,\n    quantity_requested: $json.quantity_requested,\n    urgency: $json.urgency,\n    date_needed: $json.date_needed,\n    justification: $json.justification,\n    requester: $json.requester\n  },\n  inventory_data: {\n    current_stock: $json.current_stock || 0,\n    par_level: $json.par_level || 20,\n    pending_orders: $json.pending_orders || 0,\n    avg_daily_usage: $json.avg_daily_usage || 0.5\n  },\n  forecast: {\n    next_7_day_occupancy: 85,\n    upcoming_events: []\n  },\n  historical: {\n    avg_weekly_consumption: ($json.avg_daily_usage || 0.5) * 7,\n    last_order_date: $json.last_order_date,\n    typical_order_qty: $json.typical_order_qty || $json.quantity_requested\n  }\n}) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "s4t5u6v7-w8x9-0123-yzab-c45678901234",
      "name": "Claude AI Validation",
      "type": "@n8n-nodes-base.anthropic",
      "typeVersion": 1,
      "position": [850, 300],
      "credentials": {
        "anthropicApi": {
          "id": "claude-api",
          "name": "Claude API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse Claude's JSON response\nconst aiResponse = $input.all()[0].json.content[0].text;\nlet decision;\n\ntry {\n  // Try to extract JSON from response\n  const jsonMatch = aiResponse.match(/```json\n?([\s\S]*?)\n?```/) || \n                    aiResponse.match(/{[\s\S]*}/);\n  const jsonStr = jsonMatch ? jsonMatch[1] || jsonMatch[0] : aiResponse;\n  decision = JSON.parse(jsonStr);\n} catch (e) {\n  // Fallback if JSON parsing fails\n  decision = {\n    decision: 'FLAG',\n    approved_quantity: 0,\n    reason: 'Could not parse AI response: ' + e.message,\n    confidence: 0,\n    flag_reason: 'Parse error'\n  };\n}\n\n// Get requisition ID from previous node\nconst reqId = $input.all()[0].json.requisition_id || \n              $input.all()[0].json.body?.requisitionId;\n\nreturn [{\n  json: {\n    requisitionId: reqId,\n    decision: decision.decision,\n    approvedQuantity: decision.approved_quantity || decision.approvedQuantity,\n    reason: decision.reason,\n    confidence: decision.confidence || 0.5,\n    flagReason: decision.flag_reason || decision.flagReason || null,\n    recommendations: decision.recommendations || [],\n    rawResponse: aiResponse\n  }\n}];"
      },
      "id": "t5u6v7w8-x9y0-1234-zabc-d56789012345",
      "name": "Parse AI Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "schema": "public",
        "table": "requisitions",
        "columns": {
          "mapping": [
            {
              "column": "status",
              "value": "={{ $json.decision === 'APPROVE' ? 'approved' : $json.decision === 'REDUCE' ? 'reduced' : $json.decision === 'REJECT' ? 'rejected' : 'flagged' }}"
            },
            {
              "column": "approved_quantity",
              "value": "={{ $json.approvedQuantity }}"
            },
            {
              "column": "ai_decision",
              "value": "={{ $json.decision }}"
            },
            {
              "column": "ai_reason",
              "value": "={{ $json.reason }}"
            },
            {
              "column": "ai_confidence",
              "value": "={{ $json.confidence }}"
            },
            {
              "column": "validated_at",
              "value": "={{ $now }}"
            }
          ]
        },
        "where": {
          "conditions": [
            {
              "column": "requisition_id",
              "value": "={{ $json.requisitionId }}",
              "condition": "equal"
            }
          ]
        }
      },
      "id": "u6v7w8x9-y0z1-2345-abcd-e67890123456",
      "name": "Update Requisition",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [1250, 300],
      "credentials": {
        "postgres": {
          "id": "postgres-local",
          "name": "Local Postgres"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $json.decision }}",
              "rightValue": "APPROVE",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        }
      },
      "id": "v7w8x9y0-z1a2-3456-bcde-f78901234567",
      "name": "Approved?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1250, 500]
    },
    {
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL || '#procurement-alerts' }}",
        "text": "✅ Requisition Approved by AI",
        "blocks": [
          {
            "type": "section",
            "text": {
              "type": "mrkdwn",
              "text": "*Requisition {{ $json.requisitionId }} Approved*\n\nItem: {{ $json.itemName }}\nQuantity: {{ $json.approvedQuantity }}\nConfidence: {{ Math.round($json.confidence * 100) }}%\n\n_{{ $json.reason }}_"
            }
          }
        ]
      },
      "id": "w8x9y0z1-a2b3-4567-cdef-g89012345678",
      "name": "Notify Approval",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [1450, 400],
      "credentials": {
        "slackApi": {
          "id": "slack-api",
          "name": "Slack API"
        }
      }
    },
    {
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL || '#procurement-alerts' }}",
        "text": "🚫 Requisition {{ $json.decision }} by AI",
        "blocks": [
          {
            "type": "section",
            "text": {
              "type": "mrkdwn",
              "text": "*Requisition {{ $json.requisitionId }} {{ $json.decision }}*\n\nItem: {{ $json.itemName }}\nOriginal Qty: {{ $json.quantityRequested }}\n{{ $json.decision === 'REDUCE' ? 'Approved Qty: ' + $json.approvedQuantity : '' }}\n\n_{{ $json.reason }}_\n\n{{ $json.flagReason ? '*Flag Reason:* ' + $json.flagReason : '' }}"
            }
          }
        ]
      },
      "id": "x9y0z1a2-b3c4-5678-defg-h90123456789",
      "name": "Notify Rejection",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [1450, 600],
      "credentials": {
        "slackApi": {
          "id": "slack-api",
          "name": "Slack API"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "jsonPayload": "={{ JSON.stringify({\n  success: true,\n  requisitionId: $json.requisitionId,\n  decision: $json.decision,\n  approvedQuantity: $json.approvedQuantity,\n  reason: $json.reason,\n  confidence: $json.confidence\n}) }}"
      },
      "id": "y0z1a2b3-c4d5-6789-efgh-i01234567890",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1650, 300]
    }
