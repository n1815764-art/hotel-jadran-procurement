    {
      "parameters": {
        "method": "POST",
        "url": "https://api.moonshot.ai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.MOONSHOT_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'kimi-k2.5', max_tokens: 800, thinking: { type: 'disabled' }, messages: [{ role: 'system', content: 'You are the AI Procurement Manager for Hotel Jadran. Generate a concise daily flash report (<200 words). Format:\\n1. ORDERS: PO count + total\\n2. INVOICES: count, match rate, exceptions\\n3. INVENTORY: below par, negative stock alerts\\n4. ALERTS: anything needing attention\\n5. ACTION NEEDED: items requiring Controller/GM decision\\n\\nRespond in plain text only. No JSON, no markdown. This goes directly into an email body.' }, { role: 'user', content: 'Generate Daily Flash Report for ' + $json.date + ':\\n\\nPOs: ' + $json.po_count + ' totaling €' + $json.po_total + '\\nInvoices: ' + $json.invoices_received + ' received, ' + $json.match_rate + '% auto-matched, ' + $json.invoice_exceptions + ' exceptions, ' + $json.disputes_sent + ' disputes\\nInventory: ' + $json.below_par_count + ' items below par\\nNegative Stock: ' + $json.negative_stock_items + '\\nOccupancy: ' + $json.avg_occupancy + '%\\nPending Approvals: ' + $json.pending_approvals }] }) }}",
        "options": {}
      },
