    {
      "parameters": {
        "jsCode": "const pos = $('Airtable - POs').first().json.records || [];\nconst invoices = $('Airtable - Invoices').first().json.records || [];\nconst inventory = $('Airtable - Inventory').first().json.records || [];\nconst occ = $('Airtable - Occupancy').first().json.records || [];\nconst budgets = $('Airtable - Budgets').first().json.records || [];\n\nconst poCount = pos.length;\nconst poTotal = pos.reduce((s, r) => s + (r.fields.total_amount || 0), 0);\nconst invCount = invoices.length;\nconst matched = invoices.filter(r => ['PERFECT_MATCH','MINOR_DISCREPANCY'].includes(r.fields.match_status?.name || r.fields.match_status)).length;\nconst matchRate = invCount > 0 ? Math.round(matched/invCount*100) : 0;\nconst belowPar = inventory.filter(r => (r.fields['Current Stock'] || 0) <= (r.fields['Reorder Point'] || 0)).length;\nconst negStock = inventory.filter(r => (r.fields['Current Stock'] || 0) < 0);\nconst negStockStr = negStock.map(r => r.fields.Name + ' (' + r.fields['Current Stock'] + ')').join(', ') || 'None';\nconst avgOcc = occ.length > 0 ? Math.round(occ.reduce((s,r) => s + ((r.fields['Occupancy %'] || 0) * 100), 0) / occ.length) : 75;\n\nreturn [{ json: {\n  date: new Date().toISOString().split('T')[0],\n  property_name: 'Hotel Jadran',\n  po_count: poCount, po_total: poTotal.toFixed(2),\n  invoices_received: invCount, invoices_matched: matched, match_rate: matchRate,\n  invoice_exceptions: invCount - matched,\n  disputes_sent: invoices.filter(r => (r.fields.match_status?.name || r.fields.match_status) === 'DISPUTE_REQUIRED').length,\n  below_par_count: belowPar,\n  negative_stock_items: negStockStr,\n  avg_occupancy: avgOcc,\n  pending_approvals: pos.filter(r => (r.fields.status?.name || r.fields.status) === 'Open').length\n} }];"
      },
      "id": "d9c4bcd3-9360-4eb1-8042-680066055c84",
