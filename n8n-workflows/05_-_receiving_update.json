    {
      "parameters": {
        "jsCode": "// Validate delivery data\nconst data = $input.first().json.body || $input.first().json;\n\nconst required = ['po_number', 'vendor_name', 'delivery_items'];\nconst missing = required.filter(field => !data[field]);\n\nif (missing.length > 0) {\n  return [{ json: { error: 'Missing required fields: ' + missing.join(', '), received: data } }];\n}\n\nif (!Array.isArray(data.delivery_items) || data.delivery_items.length === 0) {\n  return [{ json: { error: 'delivery_items must be a non-empty array', received: data.delivery_items } }];\n}\n\nconst receivingId = 'REC-' + new Date().getFullYear() + '-' + String(Date.now()).slice(-4);\n\nconst items = data.delivery_items.map(item => ({\n  item_name: item.item_name,\n  qty_ordered: item.quantity_ordered || 0,\n  qty_received: item.quantity_received || 0,\n  unit: item.unit || 'each',\n  condition_notes: item.notes || 'Good'\n}));\n\nconst hasDiscrepancy = items.some(i => i.qty_ordered !== i.qty_received);\n\nreturn [{ json: {\n  receiving_id: receivingId,\n  po_number: data.po_number,\n  vendor_name: data.vendor_name,\n  date_received: data.delivery_date || new Date().toISOString().split('T')[0],\n  received_by: data.received_by || 'Unknown',\n  items: items,\n  items_received_json: JSON.stringify(items),\n  has_discrepancy: hasDiscrepancy,\n  temperature: data.temperature || null,\n  quality_issues: data.quality_issues || false\n} }];"
      },
      "id": "defec33f-7c92-41ab-842d-30ec73c72654",
      "name": "Validate Delivery",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        208
      ]
    },
    {
      "parameters": {
        "url": "https://api.airtable.com/v0/appjHlTQID87ODAJL/PO_Log",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "airtableTokenApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filterByFormula",
              "value": "=FIND(SUBSTITUTE(SUBSTITUTE(\"{{ $json.po_number }}\",\"PO\",\"\"),\" \",\"\"),SUBSTITUTE(SUBSTITUTE({po_number},\"PO\",\"\"),\" \",\"\"))>0"
            }
          ]
        },
        "options": {}
      },
      "id": "61a2a8b4-c1c0-448b-af84-468e57c5d967",
      "name": "Get PO Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        448,
        208
      ],
      "credentials": {
        "airtableTokenApi": {
          "id": "dmzc6SYrfINDEidP",
          "name": "Airtable Personal Access Token account"
        }
      }
