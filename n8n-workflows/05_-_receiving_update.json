        "jsCode": "// No discrepancy path - build audit body\nconst data = $('Code - Prepare Receiving Record').first().json;\n\nconst auditBody = JSON.stringify({ records: [{ fields: {\n  reference_id: data.receiving_id,\n  event_type: 'Approved',\n  actor: data.received_by,\n  details: 'Delivery received for ' + data.po_number + ' from ' + data.vendor_name + ' — Complete, no issues'\n} }] });\n\nreturn [{ json: { audit_body: auditBody, ...data } }];"
