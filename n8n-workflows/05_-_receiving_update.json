      "id": "483c5d8c-98cf-401e-becf-085c80d1be36",
      "name": "Code - Merge Audit Path",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1616,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const delivery = $('Code - Prepare Receiving Record').first().json;\nconst poResp = $('Get PO Data').first().json;\nconst poRecordId = poResp.records && poResp.records.length > 0 ? poResp.records[0].id : null;\nconst newStatus = delivery.has_discrepancy ? 'Partially Received' : 'Fully Received';\n\nif (!poRecordId) {\n  return [{ json: { ...delivery, po_record_id: null, po_new_status: newStatus, skip_po_update: true } }];\n}\n\nconst updateBody = JSON.stringify({ fields: { status: newStatus } });\nreturn [{ json: { ...delivery, po_record_id: poRecordId, po_new_status: newStatus, skip_po_update: false, po_update_body: updateBody } }];"
      },
