        "jsCode": "let auditBody;\ntry {\n  auditBody = $('Code - Build Details').first().json.audit_body;\n} catch(e) {\n  auditBody = $('Code - No Discrepancy Audit').first().json.audit_body;\n}\nreturn [{ json: { audit_body: auditBody } }];"
