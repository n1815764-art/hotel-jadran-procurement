      "id": "72c8c29e-a799-4fa0-b39a-3abae09738c0",
      "name": "Has Discrepancy?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1120,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build discrepancy details for Slack and AI\nconst data = $('Code - Prepare Receiving Record').first().json;\nconst items = data.items || [];\nconst discrepancies = items.filter(i => i.qty_ordered !== i.qty_received);\n\nconst discList = discrepancies.map(d => d.item_name + ': ordered ' + d.qty_ordered + ', received ' + d.qty_received + ' ' + d.unit).join('\\n');\n\nconst slackMsg = '⚠️ *Delivery Discrepancy Detected*\\n\\nPO: ' + data.po_number + '\\nVendor: ' + data.vendor_name + '\\nReceived by: ' + data.received_by + '\\n\\n*Discrepancies:*\\n' + discList + '\\n\\n@controller';\n\nconst auditBody = JSON.stringify({ records: [{ fields: {\n  reference_id: data.receiving_id,\n  event_type: 'Approved',\n  actor: data.received_by,\n  details: 'Delivery received for ' + data.po_number + ' from ' + data.vendor_name + (data.has_discrepancy ? ' — DISCREPANCY: ' + discList : ' — Complete, no issues')\n} }] });\n\nreturn [{ json: { slack_msg: slackMsg, audit_body: auditBody, ...data } }];"
      },
