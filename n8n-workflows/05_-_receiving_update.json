    {
      "parameters": {
        "jsCode": "// Prepare Receiving_Log record\nconst delivery = $('Validate Delivery').first().json;\nconst poResp = $input.first().json;\nconst poFound = poResp.records?.length > 0;\n\nconst status = delivery.has_discrepancy ? 'Partial' : 'Complete';\n\nconst createBody = JSON.stringify({ records: [{ fields: {\n  receiving_id: delivery.receiving_id,\n  po_number: delivery.po_number,\n  vendor_name: delivery.vendor_name,\n  date_received: delivery.date_received,\n  received_by: delivery.received_by,\n  items_received_json: delivery.items_received_json,\n  status: status,\n  notes: delivery.quality_issues ? 'Quality issues reported' : ''\n} }] });\n\nreturn [{ json: { ...delivery, po_found: poFound, create_body: createBody } }];"
      },
      "id": "0f2cf15c-9b7b-49cd-bfb6-4c84d89f6b0c",
      "name": "Code - Prepare Receiving Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
