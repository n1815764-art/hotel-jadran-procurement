        "parameters": {
          "jsCode": "// Merge inventory items with occupancy context\nconst inventoryResp = $('Airtable - Get Items Below Reorder Point').first().json;\nconst occResp = $input.first().json;\nconst items = inventoryResp.records || [];\nconst occRecords = occResp.records || [];\n\n// Calculate average occupancy\nconst avgOcc = occRecords.length > 0\n  ? Math.round(occRecords.reduce((s, r) => s + (r.fields['Occupancy %'] || 0.75) * 100, 0) / occRecords.length)\n  : 75;\n\n// Get events\nconst events = occRecords\n  .filter(r => r.fields.Events && r.fields.Events.trim())\n  .map(r => r.fields.Events)\n  .join('; ') || 'None';\n\n// Output one item per record for the loop\nconst results = items.map(item => ({\n  json: {\n    ...item.fields,\n    item_record_id: item.id,\n    item_name: item.fields.Name || '',\n    current_stock: item.fields['Current Stock'] || 0,\n    par_level: item.fields['Par Level'] || 0,\n    reorder_point: item.fields['Reorder Point'] || 0,\n    unit: item.fields.Unit || 'each',\n    unit_cost: item.fields['Unit Cost'] || 0,\n    category: item.fields.Category || '',\n    occupancy_avg: avgOcc,\n    events: events\n  }\n}));\n\nreturn results.length > 0 ? results : [{ json: { no_items: true } }];"
        },
