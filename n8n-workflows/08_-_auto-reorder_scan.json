    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst content = response.choices[0].message.content;\nconst parsed = JSON.parse(content.replace(/```json|```/g, '').trim());\n\nlet itemData;\ntry { itemData = $('IF Negative Stock (Data Error)').first().json; }\ncatch(e) { itemData = $('Code - Merge Items with Occupancy').first().json; }\n\nreturn [{ json: { ...parsed, item_name: itemData.item_name, unit: itemData.unit, current_stock: itemData.current_stock, unit_cost: itemData.unit_cost, category: itemData.category } }];"
      },
