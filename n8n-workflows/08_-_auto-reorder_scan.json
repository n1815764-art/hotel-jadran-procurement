        "parameters": {
          "jsCode": "// Build daily summary\nconst items = $input.all();\nlet summary = '📋 *AUTO-REORDER SCAN COMPLETE* — ' + new Date().toISOString().split('T')[0] + '\\n\\n';\n\nconst ordered = items.filter(i => i.json.optimal_qty > 0 && !i.json.data_error);\nconst blocked = items.filter(i => i.json.data_error);\nconst skipped = items.filter(i => !i.json.optimal_qty && !i.json.data_error && !i.json.no_items);\n\nif (ordered.length > 0) {\n  summary += '*Orders Triggered (' + ordered.length + '):*\\n';\n  ordered.forEach(i => { summary += '  ' + i.json.item_name + ': ' + i.json.optimal_qty + ' ' + i.json.unit + ' (€' + i.json.order_total + ')\\n'; });\n}\nif (blocked.length > 0) {\n  summary += '\\n*BLOCKED — Data Errors (' + blocked.length + '):*\\n';\n  blocked.forEach(i => { summary += '  ' + i.json.item_name + ': stock at ' + i.json.current_stock + ' — NEGATIVE STOCK\\n'; });\n}\nif (ordered.length === 0 && blocked.length === 0) {\n  summary += 'All items above par or no items need reordering today.';\n}\n\nconst auditBody = JSON.stringify({ records: [{ fields: { reference_id: 'SCAN-' + new Date().toISOString().split('T')[0], event_type: 'Approved', actor: 'System', details: 'Auto-reorder scan: ' + ordered.length + ' orders, ' + blocked.length + ' blocked' } }] });\n\nreturn [{ json: { summary: summary, audit_body: auditBody } }];"
