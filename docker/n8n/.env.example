# n8n Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Database Configuration
# ============================================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=n8n

# ============================================
# REQUIRED: n8n Security
# ============================================
# Generate a strong encryption key:
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=your_encryption_key_here

# Basic auth for n8n web interface
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_admin_password_here

# ============================================
# REQUIRED: Host Configuration
# ============================================
# For local development:
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# For production with domain:
# N8N_HOST=automation.yourhotel.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://automation.yourhotel.com/

# ============================================
# Optional: Timezone
# ============================================
GENERIC_TIMEZONE=America/Los_Angeles

# ============================================
# Optional: SMTP Configuration (for email notifications)
# ============================================
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=your-email@gmail.com
N8N_SMTP_PASS=your-app-password
N8N_SMTP_SENDER="Hotel Automation <your-email@gmail.com>"

# ============================================
# Optional: Advanced Settings
# ============================================
# EXECUTIONS_MODE=queue  # Uncomment for Redis queue mode (high volume)
# N8N_LOG_LEVEL=info
# N8N_LOG_OUTPUT=console
